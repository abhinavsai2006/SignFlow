# Copy this file to .env and fill in values
# Use a local MongoDB URI or a MongoDB Atlas connection string
# Local example:
# MONGODB_URI=mongodb://localhost:27017/doc-sign-app

# MongoDB Atlas example (replace <user>, <password>, <cluster> and <dbname>):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Optional: set PORT to override default 5000
# PORT=5000
